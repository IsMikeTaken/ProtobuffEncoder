<!--
  MSBuild targets for auto-generating .proto schema files from [ProtoContract] types.

  Include this in your .csproj:
    <Import Project="..\ProtobuffEncoder\build\ProtobuffEncoder.targets" />

  Configure with properties:
    <ProtoOutputDir>protos</ProtoOutputDir>        (default: protos)
    <GenerateProtoOnBuild>true</GenerateProtoOnBuild>  (default: true)
-->
<Project>
  <PropertyGroup>
    <ProtoOutputDir Condition="'$(ProtoOutputDir)' == ''">protos</ProtoOutputDir>
    <GenerateProtoOnBuild Condition="'$(GenerateProtoOnBuild)' == ''">true</GenerateProtoOnBuild>
  </PropertyGroup>

  <Target Name="GenerateProtoSchemas"
          AfterTargets="Build"
          Condition="'$(GenerateProtoOnBuild)' == 'true'">

    <Exec Command="dotnet run --project &quot;$(MSBuildThisFileDirectory)..\..\..\ProtobuffEncoder.Tool\ProtobuffEncoder.Tool.csproj&quot; -- &quot;$(TargetPath)&quot; &quot;$(ProjectDir)$(ProtoOutputDir)&quot; &quot;$(ProjectDir)$(ProjectFileName)&quot;"
          WorkingDirectory="$(SolutionDir)"
          ConsoleToMsBuild="true" />

    <Message Text="Proto schemas generated to $(ProtoOutputDir)/" Importance="high" />
  </Target>
</Project>
